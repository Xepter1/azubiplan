# Vorlage für die Umgebungsvariablen. Kopieren nach .env und Werte anpassen:
#   cp .env.example .env
#
# Lokale Entwicklung nutzt die DB aus docker-compose.yml (Werte unten passen dazu).
DATABASE_URL="postgresql://azubiplan:azubiplan_local_dev@localhost:5432/azubiplan?schema=public"

# Auth.js (Login) — eigenen Wert erzeugen mit:  openssl rand -base64 32
AUTH_SECRET="bitte-zufallswert-einsetzen"
AUTH_TRUST_HOST=true
