// AzubiPlan — Prisma-Schema (v0)
// Abgeleitet aus ARCHITECTURE.md, Abschnitt 6 (Kern-Datenmodell).
//
// Grundregeln (siehe ARCHITECTURE.md):
//  - Jede personenbezogene Tabelle trägt `tenantId` (Mandantentrennung).
//  - `tenantId` ist überall indiziert (Performance / kein N+1 auf Filterspalte).
//  - Soft-Delete (`deletedAt`) von Tag 1 für die fachlichen Kernobjekte.
//
// WICHTIG: PostgreSQL Row-Level-Security (RLS) wird NICHT von Prisma verwaltet.
// Die RLS-Policies kommen in einem eigenen, getesteten Schritt als SQL-Migration
// (Risiko Nr. 2 in der Architektur — ein Isolations-Leck = DSGVO-Vorfall).
//
// Mit "TODO (klären)" markierte Stellen sind bewusste v0-Annahmen, die wir
// gemeinsam bestätigen sollten, bevor sie in echten Code/UI gegossen werden.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AUSBILDER
  AZUBI
  AUSBILDUNGSBEAUFTRAGTER
}

/// Art einer Azubi-Abwesenheit im Planer (blockt Einsätze — überschreibbar).
enum AbsenceType {
  URLAUB
  PRUEFUNG
  PRUEFUNGSVORBEREITUNG
}

/// Mandant (Firma). Wurzel der gesamten Datentrennung.
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  apprentices           Apprentice[]
  departments           Department[]
  professions           Profession[]
  learningContents      LearningContent[]
  requiredContents      RequiredContent[]
  taughtContents        TaughtContent[]
  placements            Placement[]
  evaluations           Evaluation[]
  grades                Grade[]
  departmentProfessions DepartmentProfession[]
  schoolBlocks          SchoolBlock[]
  absenceBlocks         AbsenceBlock[]
  departmentBlocks      DepartmentBlock[]
  schoolClasses         SchoolClass[]
  subjects              Subject[]
  classSubjects         ClassSubject[]
}

/// Login-fähiger Nutzer mit Rolle. Azubis können (optional) einen User-Account haben.
model User {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @db.Uuid
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email    String
  name     String?
  role     UserRole @default(AZUBI)

  // Passwort-Hash (bcrypt) für Login via Credentials-Provider.
  // Optional, da spätere SSO-/Keycloak-User keinen lokalen Hash brauchen.
  passwordHash String?

  // TODO (klären): Ausbilder/Ausbildungsbeauftragte gehören i.d.R. zu einer Abteilung.
  departmentId String?     @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Gegenstück zur optionalen Azubi-Verknüpfung (Apprentice.user).
  apprentice       Apprentice?
  // Von diesem User erstellte Beurteilungen (z.B. Ausbildungsbeauftragter).
  givenEvaluations Evaluation[] @relation("EvaluatorUser")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, email]) // E-Mail eindeutig je Mandant
  @@index([tenantId])
  @@index([departmentId])
}

/// Beruf / Ausbildungsgang. Hängt am Ausbildungsrahmenplan (REQUIRED_CONTENT).
model Profession {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bezeichnung String

  apprentices         Apprentice[]
  requiredContents    RequiredContent[]
  // Abteilungen, die für diesen Beruf als Einsatzort geeignet sind.
  suitableDepartments DepartmentProfession[]
  // Schulklassen (Jahrgänge) dieses Berufs.
  schoolClasses       SchoolClass[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

/// Auszubildende:r.
model Apprentice {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @db.Uuid
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vorname  String
  nachname String
  start    DateTime @db.Date
  ende     DateTime @db.Date

  professionId String?     @db.Uuid
  profession   Profession? @relation(fields: [professionId], references: [id], onDelete: SetNull)

  // Schulklasse (Jahrgang) des Azubis — steuert seine Fächer (Noten) und
  // Berufsschulwochen. Optional, da nicht jeder Azubi sofort zugeordnet ist.
  classId String?      @db.Uuid
  class   SchoolClass? @relation(fields: [classId], references: [id], onDelete: SetNull)

  // TODO (klären): Azubi-Login — 1:1-Verknüpfung zu einem User-Account (optional).
  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  placements    Placement[]
  grades        Grade[]
  absenceBlocks AbsenceBlock[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([professionId])
  @@index([classId])
}

/// Abteilung, durch die Azubis rotieren. Vermittelt bestimmte Lerninhalte.
model Department {
  id         String @id @default(uuid()) @db.Uuid
  tenantId   String @db.Uuid
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  kapazitaet Int? // max. gleichzeitige Azubis (optional)

  taughtContents TaughtContent[]
  placements     Placement[]
  users          User[] // Ausbilder / Ausbildungsbeauftragte dieser Abteilung
  // Für welche Berufe ist diese Abteilung als Einsatzort geeignet.
  suitableFor    DepartmentProfession[]
  // Gesperrte Zeiträume (z. B. Betriebsurlaub).
  blocks         DepartmentBlock[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

/// Einzelner Lerninhalt (Baustein des Rahmenplans bzw. dessen, was Abteilungen vermitteln).
model LearningContent {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  titel    String

  requiredFor RequiredContent[]
  taughtIn    TaughtContent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

/// Verknüpfung Beruf ↔ Lerninhalt: "dieser Inhalt ist Pflicht für diesen Beruf".
model RequiredContent {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  professionId      String          @db.Uuid
  profession        Profession      @relation(fields: [professionId], references: [id], onDelete: Cascade)
  learningContentId String          @db.Uuid
  learningContent   LearningContent @relation(fields: [learningContentId], references: [id], onDelete: Cascade)

  @@unique([professionId, learningContentId])
  @@index([tenantId])
  @@index([learningContentId])
}

/// Verknüpfung Abteilung ↔ Lerninhalt: "diese Abteilung vermittelt diesen Inhalt".
model TaughtContent {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  departmentId      String          @db.Uuid
  department        Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  learningContentId String          @db.Uuid
  learningContent   LearningContent @relation(fields: [learningContentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, learningContentId])
  @@index([tenantId])
  @@index([learningContentId])
}

/// Einsatz: ein Azubi ist von–bis in einer Abteilung (Rotation).
model Placement {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apprenticeId String     @db.Uuid
  apprentice   Apprentice @relation(fields: [apprenticeId], references: [id], onDelete: Cascade)
  departmentId String     @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  von DateTime @db.Date
  bis DateTime @db.Date

  // 1:1 — eine Beurteilung je Einsatz (optional, entsteht nach dem Einsatz).
  evaluation Evaluation?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // TODO (klären): Dürfen sich Einsätze eines Azubis zeitlich überlappen (parallel)
  // oder sind sie strikt sequentiell? Beeinflusst Validierung & Abdeckungs-Check.
  @@index([tenantId])
  @@index([apprenticeId, von])
  @@index([departmentId, von, bis])
}

/// Beurteilung eines Azubis durch die Abteilung nach einem Einsatz.
model Evaluation {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  placementId String    @unique @db.Uuid
  placement   Placement @relation(fields: [placementId], references: [id], onDelete: Cascade)

  // Bewertungsbogen — 4 feste Kriterien, je 1–5 Sterne (5 = beste).
  fachlich           Int?
  selbststaendigkeit Int?
  sorgfalt           Int?
  teamverhalten      Int?
  kommentar          String?

  // Gesamt-Note (1–6, 1 = beste) — beim Abschicken aus den Sternen abgeleitet,
  // fürs Azubi-Profil ("Bewertung · gut").
  bewertung Int?

  // null = Entwurf (zwischengespeichert); gesetzt = abgeschickt.
  submittedAt DateTime?

  evaluatorUserId String? @db.Uuid
  evaluator       User?   @relation("EvaluatorUser", fields: [evaluatorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

/// Note (vom Azubi eingetragen).
model Grade {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apprenticeId String     @db.Uuid
  apprentice   Apprentice @relation(fields: [apprenticeId], references: [id], onDelete: Cascade)

  // Fach, auf das sich die Note bezieht. Der Azubi wählt beim Eintragen nur aus
  // den Fächern seiner Klasse (ClassSubject).
  subjectId String  @db.Uuid
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  // TODO (klären): Skala (1–6?), Berufsschule vs. Betrieb, Zeitraum/Schuljahr.
  wert  Decimal  @db.Decimal(3, 1)
  datum DateTime @db.Date

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([apprenticeId])
  @@index([subjectId])
}

/// Eignung: welche Abteilung kommt für welchen Beruf als Einsatzort infrage.
model DepartmentProfession {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  departmentId String     @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  professionId String     @db.Uuid
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  // Soll-Dauer (in Wochen), die ein Azubi dieses Berufs in dieser Abteilung
  // verbringen soll. Wird überschritten → Station gilt als "durchlaufen".
  // null = noch nicht festgelegt (wird später gepflegt).
  sollWochen Int?

  @@unique([departmentId, professionId])
  @@index([tenantId])
  @@index([professionId])
}

/// Berufsschul-Block (Blockunterricht) einer Schulklasse. Da eine Klasse einem
/// Beruf + Jahrgang entspricht, sind die Wochen damit pro Jahrgang exakt.
model SchoolBlock {
  id       String      @id @default(uuid()) @db.Uuid
  tenantId String      @db.Uuid
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId  String      @db.Uuid
  class    SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  von DateTime @db.Date
  bis DateTime @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([classId])
}

/// Abwesenheit eines Azubis: Urlaub oder Prüfung(svorbereitung).
model AbsenceBlock {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apprenticeId String     @db.Uuid
  apprentice   Apprentice @relation(fields: [apprenticeId], references: [id], onDelete: Cascade)

  typ AbsenceType
  von DateTime    @db.Date
  bis DateTime    @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([apprenticeId])
}

/// Gesperrter Zeitraum einer Abteilung (z. B. Betriebsurlaub).
model DepartmentBlock {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentId String     @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  grund String?
  von   DateTime @db.Date
  bis   DateTime @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([departmentId])
}

/// Schulklasse = Jahrgang eines Berufs (z. B. „Mechatroniker 2027"). Bündelt die
/// Fächer (für Noten) und die Berufsschulwochen, weil sich der Lehrplan von
/// Jahrgang zu Jahrgang unterscheiden kann.
model SchoolClass {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  professionId String     @db.Uuid
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  jahrgang     Int // Einschulungsjahr, z. B. 2027

  apprentices   Apprentice[]
  classSubjects ClassSubject[]
  schoolBlocks  SchoolBlock[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([professionId])
}

/// Schulfach (z. B. „Steuerungstechnik", „WiSo"). Pro Mandant; in mehreren
/// Klassen wiederverwendbar (ermöglicht „Fächer aus anderer Klasse übernehmen").
model Subject {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String

  classSubjects ClassSubject[]
  grades        Grade[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

/// Verknüpfung Klasse ↔ Fach: „dieses Fach wird in dieser Klasse unterrichtet".
model ClassSubject {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  classId   String      @db.Uuid
  class     SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String      @db.Uuid
  subject   Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([tenantId])
  @@index([subjectId])
}
